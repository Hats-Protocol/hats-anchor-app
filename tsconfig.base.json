{
  "compilerOptions": {
    "allowSyntheticDefaultImports": true,
    "baseUrl": ".",
    "declaration": false,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "importHelpers": true,
    "isolatedModules": true,
    "lib": ["ES2018", "dom"],
    "module": "ESNext",
    "moduleResolution": "node",
    "rootDir": ".",
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "sourceMap": true,
    "strict": true,
    "target": "ES2020",
    "types": ["node"],
    "paths": {
      "@hatsprotocol/constants": ["./libs/constants/src/index.ts"],
      "contexts": ["./libs/contexts/src/index.ts"],
      "forms": ["./libs/forms/src/index.ts"],
      "hats-hooks": ["./libs/hats-hooks/src/index.ts"],
      "hats-utils": ["./libs/hats-utils/src/index.ts"],
      "hooks": ["./libs/hooks/src/index.ts"],
      "icons": ["./libs/icons/src/index.ts"],
      "modules-hooks": ["./libs/modules-hooks/src/index.ts"],
      "modules-ui": ["./libs/modules-ui/src/index.ts"],
      "molecules": ["./libs/molecules/src/index.ts"],
      "organisms": ["./libs/organisms/src/index.ts"],
      "pages": ["./libs/pages/src/index.ts"],
      "shared": ["./libs/shared/src/index.ts"],
      "types": ["./libs/types/src/index.ts"],
      "ui": ["./libs/ui/src/index.ts"],
      "utils": ["./libs/utils/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "tmp", "dist", ".nx"]
}
