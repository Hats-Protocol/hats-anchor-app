{
  "compilerOptions": {
    "types": ["node", "jest"],
    "rootDir": ".",
    "baseUrl": ".",
    "sourceMap": true,
    "declaration": false,
    "moduleResolution": "node",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "es2016",
    "module": "esnext",
    "lib": ["es2017", "dom"],
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "paths": {
      "ui": ["libs/ui/src/index.ts"],
      "ui/server": ["libs/ui/src/server.ts"],
      "app-constants": ["./libs/app-constants/src/index"],
      "app-hooks": ["./libs/app-hooks/src/index"],
      "app-utils": ["./libs/app-utils/src/index"],
      "hats-hooks": ["./libs/hats-hooks/src/index"],
      "hats-types": ["./libs/hats-types/src/index"],
      "hats-utils": ["./libs/hats-utils/src/index"],
      "shared-utils": ["./libs/shared-utils/src/index"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx"],
  "exclude": ["node_modules", "tmp", "dist", ".nx"]
}
