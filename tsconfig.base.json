{
  "compilerOptions": {
    "types": ["node", "jest"],
    "rootDir": ".",
    "baseUrl": ".",
    "sourceMap": true,
    "declaration": false,
    "moduleResolution": "node",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "es2016",
    "module": "esnext",
    "lib": ["es2017", "dom"],
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "paths": {
      "@hatsprotocol/constants": ["./libs/constants/src/index"],
      "contexts": ["./libs/contexts/src/index"],
      "forms": ["./libs/forms/src/index"],
      "hats-hooks": ["./libs/hats-hooks/src/index"],
      "hats-utils": ["./libs/hats-utils/src/index"],
      "hooks": ["./libs/hooks/src/index"],
      "icons": ["./libs/icons/src/index"],
      "modules-ui": ["./libs/modules-ui/src/index"],
      "pages": ["./libs/pages/src/index"],
      "shared": ["./libs/shared/src/index"],
      "types": ["./libs/types/src/index"],
      "ui": ["./libs/ui/src/index.ts"],
      "utils": ["./libs/utils/src/index"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx", "*.d.ts"],
  "exclude": ["node_modules", "tmp", "dist", ".nx"]
}
