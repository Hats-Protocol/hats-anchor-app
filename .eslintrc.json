{
  "root": true,
  "parser": "@typescript-eslint/parser",
  "plugins": [
    "@typescript-eslint",
    "prettier",
    "babel",
    "import",
    "simple-import-sort",
    "@tanstack/query",
    "@nx"
  ],
  "parserOptions": {
    "ecmaVersion": 2023
  },
  "overrides": [
    {
      "files": ["*.ts", "*.tsx", "*.js", "*.jsx"],
      "rules": {
        "@nx/enforce-module-boundaries": [
          "error",
          {
            "enforceBuildableLibDependency": true,
            "allow": [],
            "depConstraints": [
              {
                "sourceTag": "*",
                "onlyDependOnLibsWithTags": ["*"]
              }
            ]
          }
        ],
        "@typescript-eslint/no-explicit-any": "warn"
      }
    }
  ],
  "extends": [
    "airbnb",
    "plugin:@tanstack/eslint-plugin-query/recommended",
    "plugin:prettier/recommended",
    "plugin:@typescript-eslint/recommended"
  ],
  "ignorePatterns": ["node_modules/*", ".nx/*", "dist/*", "tmp/*"],
  "rules": {
    // gen
    "no-use-before-define": "off",
    "no-unused-vars": "off",
    // import
    "import/extensions": [
      "error",
      "ignorePackages",
      {
        "js": "never",
        "jsx": "never",
        "ts": "never",
        "tsx": "never"
      }
    ],

    // import sort
    // increase the severity of rules so they are auto-fixable
    "simple-import-sort/imports": "error",
    "simple-import-sort/exports": "error",
    "prettier/prettier": "error"
  },
  "settings": {
    "import/resolver": {
      "typescript": {
        "project": [
          "tsconfig.json",
          "apps/*/tsconfig.json",
          "libs/*/tsconfig.json"
        ]
      },
      "node": {
        "project": [
          "tsconfig.json",
          "apps/*/tsconfig.json",
          "libs/*/tsconfig.json"
        ]
      }
    }
  }
}
