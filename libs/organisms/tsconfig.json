{
  "compilerOptions": {
    "jsx": "react-jsx",
    "allowJs": false,
    "esModuleInterop": false,
    "declaration": true,
    "declarationMap": true,
    "strict": true,
    "types": ["wagmi", "viem"]
  },
  "references": [
    { "path": "../config/tsconfig.lib.json" },
    { "path": "../constants/tsconfig.lib.json" },
    { "path": "../contexts/tsconfig.lib.json" },
    { "path": "../hats-hooks/tsconfig.lib.json" },
    { "path": "../hats-utils/tsconfig.lib.json" },
    { "path": "../hooks/tsconfig.lib.json" },
    { "path": "../icons/tsconfig.lib.json" },
    { "path": "../molecules/tsconfig.lib.json" },
    { "path": "../shared/tsconfig.lib.json" },
    { "path": "../types/tsconfig.lib.json" },
    { "path": "../ui/tsconfig.lib.json" },
    { "path": "../utils/tsconfig.lib.json" }
  ],
  "include": ["src/**/*.ts", "src/**/*.tsx", "**/*.d.ts", "../types/**/*.d.ts", "tailwind.config.ts"],
  "extends": "../../tsconfig.base.json"
}
