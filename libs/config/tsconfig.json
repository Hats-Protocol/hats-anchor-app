{
  "compilerOptions": {
    "jsx": "react-jsx",
    "allowJs": false,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "declaration": true,
    "declarationMap": true,
    "strict": true
  },
  "references": [{ "path": "../shared/tsconfig.lib.json" }, { "path": "../types/tsconfig.lib.json" }],
  "include": ["src/**/*.ts", "src/**/*.tsx", "src/**/*.d.ts"],
  "extends": "../../tsconfig.base.json"
}
