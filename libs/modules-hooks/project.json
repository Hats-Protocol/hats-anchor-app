{
  "name": "modules-hooks",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/modules-hooks/src",
  "projectType": "library",
  "tags": [],
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/libs/modules-hooks",
        "main": "libs/modules-hooks/src/index.ts",
        "packageJson": "libs/modules-hooks/package.json",
        "tsConfig": "libs/modules-hooks/tsconfig.lib.json",
        "assets": ["libs/modules-hooks/*.md"],
        "updateBuildableProjectDepsInPackageJson": true
      }
    },
    "publish": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node tools/scripts/publish.mjs modules-hooks {args.ver} {args.tag}"
      },
      "dependsOn": [{ "target": "build" }]
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": ["{options.outputFile}"]
    }
  }
}
